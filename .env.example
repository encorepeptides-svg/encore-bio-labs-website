# Browser-safe Supabase project settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Never expose SUPABASE_SERVICE_ROLE_KEY through a VITE_ variable.
# Configure service-role and privileged secrets only in Supabase Edge Functions.

# Interim WhatsApp/Instagram checkout handoff (src/config/interimCheckout.ts).
# Digits only with country code; falls back to the site-wide WhatsApp number.
VITE_WHATSAPP_PHONE=
# Instagram business username without the @; falls back to encorebiolabs.
VITE_INSTAGRAM_USERNAME=
