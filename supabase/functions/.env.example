# Server-only shipping provider credentials. Never prefix these with VITE_.
EASYPOST_API_KEY=

# Required to request live carrier rates. All dimensions are inches; weight is
# ounces per kit and is multiplied by the server-verified cart kit count.
EASYPOST_FROM_NAME=Encore Bio Labs
EASYPOST_FROM_STREET1=
EASYPOST_FROM_STREET2=
EASYPOST_FROM_CITY=
EASYPOST_FROM_STATE=
EASYPOST_FROM_ZIP=
EASYPOST_FROM_COUNTRY=US
EASYPOST_FROM_PHONE=
EASYPOST_PARCEL_LENGTH_IN=
EASYPOST_PARCEL_WIDTH_IN=
EASYPOST_PARCEL_HEIGHT_IN=
EASYPOST_WEIGHT_OZ_PER_KIT=

# Comma-separated production site origins allowed to call the function.
STOREFRONT_ALLOWED_ORIGINS=

# Each center is the distribution point used for the 10-mile home-delivery
# radius. Pickup is free; verified home delivery is fixed at $10. Missing
# coordinates, point details, or timing intentionally trigger manual review.
LOCAL_DELIVERY_EL_PASO_CENTER_LATITUDE=
LOCAL_DELIVERY_EL_PASO_CENTER_LONGITUDE=
LOCAL_DELIVERY_EL_PASO_HOME_DELIVERY_TIME=
LOCAL_DELIVERY_EL_PASO_PICKUP_NAME=
LOCAL_DELIVERY_EL_PASO_PICKUP_ADDRESS=
LOCAL_DELIVERY_EL_PASO_PICKUP_TIME=

LOCAL_DELIVERY_JUAREZ_CENTER_LATITUDE=
LOCAL_DELIVERY_JUAREZ_CENTER_LONGITUDE=
LOCAL_DELIVERY_JUAREZ_HOME_DELIVERY_TIME=
LOCAL_DELIVERY_JUAREZ_PICKUP_NAME=
LOCAL_DELIVERY_JUAREZ_PICKUP_ADDRESS=
LOCAL_DELIVERY_JUAREZ_PICKUP_TIME=

LOCAL_DELIVERY_CHIHUAHUA_CENTER_LATITUDE=
LOCAL_DELIVERY_CHIHUAHUA_CENTER_LONGITUDE=
LOCAL_DELIVERY_CHIHUAHUA_HOME_DELIVERY_TIME=
LOCAL_DELIVERY_CHIHUAHUA_PICKUP_NAME=
LOCAL_DELIVERY_CHIHUAHUA_PICKUP_ADDRESS=
LOCAL_DELIVERY_CHIHUAHUA_PICKUP_TIME=
