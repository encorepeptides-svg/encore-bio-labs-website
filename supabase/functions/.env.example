# Server-only shipping provider credentials. Never prefix these with VITE_.
EASYPOST_API_KEY=

# Required to request live carrier rates. All dimensions are inches; weight is
# ounces per kit and is multiplied by the server-verified cart kit count.
EASYPOST_FROM_NAME=Encore Bio Labs
EASYPOST_FROM_STREET1=
EASYPOST_FROM_STREET2=
EASYPOST_FROM_CITY=
EASYPOST_FROM_STATE=
EASYPOST_FROM_ZIP=
EASYPOST_FROM_COUNTRY=US
EASYPOST_FROM_PHONE=
EASYPOST_PARCEL_LENGTH_IN=
EASYPOST_PARCEL_WIDTH_IN=
EASYPOST_PARCEL_HEIGHT_IN=
EASYPOST_WEIGHT_OZ_PER_KIT=

# Comma-separated production site origins allowed to call the function.
STOREFRONT_ALLOWED_ORIGINS=

# Local delivery coverage is intentionally configuration-only. If a postal-code
# list, fee, or time is missing, checkout requests manual review and never
# invents availability, cost, or timing.
LOCAL_DELIVERY_EL_PASO_POSTAL_CODES=
LOCAL_DELIVERY_EL_PASO_FEE_CENTS=
LOCAL_DELIVERY_EL_PASO_TIME=
LOCAL_DELIVERY_JUAREZ_POSTAL_CODES=
LOCAL_DELIVERY_JUAREZ_FEE_CENTS=
LOCAL_DELIVERY_JUAREZ_TIME=
LOCAL_DELIVERY_CHIHUAHUA_POSTAL_CODES=
LOCAL_DELIVERY_CHIHUAHUA_FEE_CENTS=
LOCAL_DELIVERY_CHIHUAHUA_TIME=
